# ------------ app settings ------------
APP_NAME="PawsPort"
APP_URL="http://localhost:8000"
APP_DESCRIPTION="Smart Digital Pet Passport"
APP_VERSION="0.1"
LICENSE_NAME="MIT"
CONTACT_NAME="PawsPort"
CONTACT_EMAIL="your-email@gmail.com"

# ------------ environment ------------
ENVIRONMENT="local"

# ------------ CORS ------------
CORS_ORIGINS=["*"] # Configure this to your frontend URL in production
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# ------------ database ------------
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=12345
POSTGRES_SERVER="db"
POSTGRES_PORT=5432
POSTGRES_DB="pawsport"
POSTGRES_ASYNC_PREFIX="postgresql+asyncpg://"

# ------------ redis cache ------------
REDIS_CACHE_HOST="redis"
REDIS_CACHE_PORT=6379

# ------------ redis queue ------------
REDIS_QUEUE_HOST="redis"
REDIS_QUEUE_PORT=6379

# ------------ redis rate limit ------------
REDIS_RATE_LIMIT_HOST="redis"
REDIS_RATE_LIMIT_PORT=6379

# ------------ redis admin session ------------
REDIS_ADMIN_SESSION_HOST="redis"
REDIS_ADMIN_SESSION_PORT=6379
REDIS_ADMIN_SESSION_DB=1

# ------------ client side cache ------------
CLIENT_CACHE_MAX_AGE=60

# ------------ crypt ------------
SECRET_KEY="your-secret-key"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------ token expiry (minutes) ------------
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=60
EMAIL_CHANGE_OTP_EXPIRE_MINUTES=15
EMAIL_CHANGE_AUTHORIZATION_TOKEN_EXPIRE_MINUTES=15
EMAIL_CHANGE_TOKEN_EXPIRE_MINUTES=15
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15

# ------------ rate limits ------------
DEFAULT_RATE_LIMIT_LIMIT=60
DEFAULT_RATE_LIMIT_PERIOD=60
DEFAULT_GUEST_RATE_LIMIT_LIMIT=20
DEFAULT_GUEST_RATE_LIMIT_PERIOD=60

# ------------ admin session (web auth) ------------
ADMIN_SESSION_TTL_SECONDS=1800
ADMIN_SESSION_ABSOLUTE_TTL_SECONDS=604800
ADMIN_SESSION_SIGNING_SECRET="your-admin-session-signing-secret"

ADMIN_SESSION_COOKIE_SECURE=False
ADMIN_SESSION_COOKIE_SAMESITE=lax
ADMIN_SESSION_COOKIE_PATH=/

ADMIN_SESSION_MAXIMUM_SESSIONS_PER_USER=3

# ------------ admin auth ------------
LOGIN_WINDOW_SECONDS=60
LOGIN_MAX_ATTEMPTS_PER_IP_USERNAME=10
LOGIN_MAX_ATTEMPTS_PER_IP=30

# ------------ admin ------------
ADMIN_NAME="admin"
ADMIN_EMAIL="admin@admin.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="@Pawsport123"
# ADMIN_PASSWORD="!Ch4ng3Th1sP4ssW0rd!"

# ------------ tiers ------------
FREE_TIER_NAME="free"
GUEST_TIER_NAME="guest"
DEFAULT_MOBILE_USER_TIER="free"
DEFAULT_GUEST_USER_TIER="guest"

# ------------ notification settings ------------
NEARBY_ALERT_CENTER_RADIUS_METERS=3_000 # 3 km

# ------------ google cloud storage (GCS) ------------
GCS_BUCKET_NAME="your-gcs-bucket-name"
GCS_SIGNED_URL_VERSION="v4"
GCS_VIEW_SIGNED_URL_EXPIRATION_MINUTES=60
GCS_DOWNLOAD_SIGNED_URL_EXPIRATION_MINUTES=3
GCS_UPLOAD_SIGNED_URL_EXPIRATION_MINUTES=3
GCS_RESUMABLE_UPLOAD_SIGNED_URL_EXPIRATION_MINUTES=1

# ------------ email (brevo) ------------
BREVO_API_KEY="your-brevo-api-key"
BREVO_SENDER_EMAIL="your-sender-email@gmail.com"
BREVO_SENDER_NAME="Pawsport"

# ------------ qdrant ------------
QDRANT_CLOUD_URL=https://your-qdrant-instance.qdrant.io
QDRANT_CLOUD_API_KEY="your-qdrant-cloud-api-key"

# ------------ ml service ------------
ML_BASE_URL="http://ml:9000"

# ------------ pet settings ------------
QR_BASE_URL="http://localhost:8000/api/v1/pets/qr"

# ------------ test ------------
TEST_NAME="Tester User"
TEST_EMAIL="test@tester.com"
TEST_USERNAME="testeruser"
TEST_PASSWORD="Str1ngT3st!"
