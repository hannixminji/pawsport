docker-compose.yml
*.sh
.editorconfig
.pre-commit-config.yaml
.idea
.vscode

# Tests & seed scripts (not part of the running app)
tests/
test/

# Docs — keep README.md for hatchling build
*.md
!README.md

# OS artifacts
.DS_Store
Thumbs.db
